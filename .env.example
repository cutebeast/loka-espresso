# Database
DB_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql+asyncpg://fnb:change-me-to-a-strong-password@db:5432/fnb

# JWT Authentication
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET_PREVIOUS=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ISSUER=fnb-api
JWT_AUDIENCE=fnb-app

# CORS (comma-separated origins)
CORS_ORIGINS=https://app.loyaltysystem.uk,https://admin.loyaltysystem.uk

# File uploads
UPLOAD_DIR=/app/uploads
CUSTOMER_APP_DIR=/app/customer-app

# Environment
ENVIRONMENT=development
ALLOW_CUSTOMER_RESET=false

# Webhooks (for 3rd party integrations — leave empty if not connected)
WEBHOOK_API_KEY=
WEBHOOK_SIGNING_SECRET=

# External POS API endpoint (optional — for auto-syncing orders to POS/KDS)
# Leave empty to use manual mode (staff re-key orders into POS terminal)
POS_API_URL=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis (for distributed rate limiting and caching)
REDIS_URL=redis://redis:6379/0
