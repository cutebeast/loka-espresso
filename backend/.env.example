# Database
DATABASE_URL=postgresql+asyncpg://fnb:change-me@localhost:5432/fnb

# JWT Authentication
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET_PREVIOUS=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ISSUER=fnb-api
JWT_AUDIENCE=fnb-app

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File uploads
UPLOAD_DIR=./uploads
CUSTOMER_APP_DIR=./customer-app

# Environment
ENVIRONMENT=development
ALLOW_CUSTOMER_RESET=false

# Webhooks (for 3rd party integrations)
WEBHOOK_API_KEY=
WEBHOOK_SIGNING_SECRET=

# External POS API endpoint
POS_API_URL=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP bypass (development only)
OTP_BYPASS_ALLOWED=false
